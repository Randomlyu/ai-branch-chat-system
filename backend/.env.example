# ========================
# 数据库配置
# ========================
# DATABASE_URL=postgresql://username:password@localhost/dbname

# ========================
# 认证配置
# ========================
SECRET_KEY=your-secret-key-here-changeme-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ========================
# 应用配置
# ========================
MAX_BRANCH_DEPTH=3

# ========================
# AI服务配置
# ========================
# 硅基流动平台API密钥
DEEPSEEK_API_KEY=sk-your-siliconflow-api-key-here
# 支持的模型列表，逗号分隔
SUPPORTED_MODELS=deepseek-ai/DeepSeek-V3.2,tencent/Hunyuan-A13B-Instruct,Qwen/Qwen3-Coder-30B-A3B-Instruct,zai-org/GLM-4.5-Air,stepfun-ai/Step-3.5-Flash,mock
# 模型友好名称映射（JSON格式）
MODEL_DISPLAY_NAMES={"deepseek-ai/DeepSeek-V3.2":"DeepSeek V3.2","tencent/Hunyuan-A13B-Instruct":"腾讯混元 A13B","Qwen/Qwen3-Coder-30B-A3B-Instruct":"通义千问 Coder 30B","zai-org/GLM-4.5-Air":"智谱GLM-4.5 Air","stepfun-ai/Step-3.5-Flash":"阶跃星辰 Step-3.5-Flash","mock":"模拟模式"}
# 默认模型
DEFAULT_MODEL=deepseek-ai/DeepSeek-V3.2
# 流式响应
STREAMING_ENABLED=true
# 硅基流动API基础URL
OPENAI_API_BASE=https://api.siliconflow.cn/v1

# ========================
# 用量控制配置
# ========================
MAX_DAILY_TOKENS=1000000
RESET_HOUR=0